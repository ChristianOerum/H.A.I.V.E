# ─────────────────────────────────────────────
#  H.A.I.V.E — Environment Configuration
#  Copy this file to .env and fill in your values
#
#  NOTE: On a fresh install you can skip most of this — the on-screen
#  first-launch setup collects HA_URL, HA_TOKEN, ALLOWED_LOCAL_PREFIXES
#  and the Master/Slave role and stores them in config/device.json.
#  Values here act as defaults / bootstrap for that screen.
# ─────────────────────────────────────────────

# ── Home Assistant ────────────────────────────
# URL of your Home Assistant instance
HA_URL=http://homeassistant.local:8123

# Long-lived access token (see instructions below)
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiI3NDQ3NWNmNDNiNDI0YzE3ODRjYWFlNDFjYTlkZDE5ZSIsImlhdCI6MTc4MjQ4NjI5NSwiZXhwIjoyMDk3ODQ2Mjk1fQ.VEimzHUkksSam_dCYGktvW2i0iYciCzl1cqoWxQSFgI

# ── Wi-Fi QR Code (optional) ──────────────────
# Displayed as a QR code via the Wi-Fi button
WIFI_SSID=Casa de oerum
WIFI_PASSWORD=Handsoffmywhiskey
WIFI_SECURITY=WPA        # WPA | WEP | nopass
WIFI_HIDDEN=false        # true | false

# ── Security ──────────────────────────────────
# Comma-separated IP prefixes allowed to access the API
# Defaults cover localhost, RFC-1918 private ranges
ALLOWED_LOCAL_PREFIXES=127.,192.168.,10.,172.

# PIN required to unlock the toolbar controls.
# Leave unset (or remove the line) to disable authentication entirely.
AUTH_PIN=1234

# ── Docker deployment (docker-compose.yml) ────
# Published image to run and auto-update. Override with your registry image.
HAIVE_IMAGE=ghcr.io/haive/haive:latest
# Host port to expose the kiosk server on.
HAIVE_PORT=3000
# How often Watchtower checks for a newer image, in seconds (default 1h).
WATCHTOWER_INTERVAL=3600