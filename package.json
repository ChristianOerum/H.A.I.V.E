    "@tresjs/cientos": "~4.2.0",
    "@tresjs/core": "^4.3.1",
    "@tresjs/nuxt": "^4.0.0",
    "@vueuse/core": "^11.3.0",
    "@vueuse/nuxt": "^11.3.0",
    "home-assistant-js-websocket": "^9.6.0",
    "nuxt": "^3.21.8",
    "pinia": "^2.3.0",
    "qrcode": "^1.5.4",
    "three": "^0.184.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/qrcode": "^1.5.6",
