{
  "name": "haive",
  "version": "2026.7.4",
  "description": "HAIVE — Home Assistant Interactive Visual Environment. A 3D Home Assistant interface for Raspberry Pi touchscreens.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "image:build": "powershell -NoProfile -ExecutionPolicy Bypass -File ./deploy/publish-image.ps1",
